# ════════════════════════════════════════════════
#   ISHU MUSIC BOT — Environment Variables
#   Copy this to .env and fill in your values
# ════════════════════════════════════════════════

# ── Telegram App Credentials ──────────────────
# Get from https://my.telegram.org/apps
API_ID=
API_HASH=

# ── Bot Token ─────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# ── Log Channel ───────────────────────────────
# Numeric chat ID of your log channel (bot must be admin)
LOGGER_ID=

# ── MongoDB ───────────────────────────────────
# Get a free cluster at https://cloud.mongodb.com
MONGO_URL=

# ── Owner ─────────────────────────────────────
# Your Telegram numeric user ID
OWNER_ID=

# ── Pyrogram Sessions ─────────────────────────
# Get string sessions from @StringFatherBot on Telegram
# At least SESSION (SESSION1) is required
SESSION=
SESSION2=
SESSION3=

# ── Download Methods ──────────────────────────

# [1] Cookies Base64 (RECOMMENDED — fastest, uses yt-dlp with your YouTube cookies)
#   How to generate:
#     1. Export your YouTube cookies as cookies.txt (use browser extension "Get cookies.txt LOCALLY")
#     2. Run: base64 -w 0 cookies.txt
#     3. Paste the output below
COOKIES_

# [2] Railway Self-Hosted YouTube API (your own Railway YT API service)
#   Deploy: https://github.com/AnonymousX1025/youtube-api
RAILWAY_YT_API_URL=https://youtube-api-music-production-824b.up.railway.app
RAILWAY_YT_API_KEY=SLtWox3TFKKHuMySdvz_4y2Ju3NlSHYk

# [3] Shruti API (optional third-party API)
#   Get key from @SHRUTIAPIBOT on Telegram
SHRUTI_API_URL=http://api01.shrutibots.site
SHRUTI_API_KEY=

# [4] xBit API (optional third-party API fallback)
#   Get key from https://t.me/tgmusic_apibot
YTPROXY_URL=https://tgapi.xbitcode.com
YT_API_KEY=

# ── Optional Settings ─────────────────────────
# Maximum song duration allowed (in minutes, default: 120)
DURATION_LIMIT=120

# Maximum songs in queue per group (default: 20)
QUEUE_LIMIT=20

# Maximum songs fetched from a playlist (default: 20)
PLAYLIST_LIMIT=20

# Enable thumbnail generation (True/False, default: True)
THUMB_GEN=True

# Enable video play mode (True/False, default: True)
VIDEO_PLAY=True

# Auto leave voice chat when queue is empty (True/False, default: False)
AUTO_LEAVE=False

# Auto end stream when no one in VC (True/False, default: False)
AUTO_END=False

# Bot default language code (default: en)
LANG_CODE=en

# Support links (shown in error messages)
SUPPORT_CHANNEL=https://t.me/titanic_network
SUPPORT_CHAT=https://t.me/+WAOT47P-70QwOTBl

# ── Image Customization ───────────────────────
DEFAULT_THUMB=https://te.legra.ph/file/3e40a408286d4eda24191.jpg
PING_IMG=https://files.catbox.moe/haagg2.png
START_IMG=https://files.catbox.moe/zvziwk.jpg